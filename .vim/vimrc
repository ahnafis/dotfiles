"     autocmd!
"     autocmd FileType html,css,javascript setlocal softtabstop=2 shiftwidth=2
" augroup END

" augroup SetJson
" autocmd!
" autocmd BufRead,BufNewFile *.json,*.jsonc set filetype=jsonc
" augroup END

" ==============================================================================
" |#4| Key mappings
" ==============================================================================
set timeout
set ttimeout
set timeoutlen=1000
set ttimeoutlen=50

let g:mapleader = ','

" Swaps
nnoremap ^ 0
nnoremap 0 ^
nnoremap <Home> ^
nnoremap <C-I> <C-A>

" Split resizing.
nnoremap <Leader>] <Cmd>resize +5<CR>
nnoremap <Leader>[ <Cmd>resize -5<CR>
nnoremap <Leader>= <Cmd>vertical resize +5<CR>
nnoremap <Leader>- <Cmd>vertical resize -5<CR>

" Editing.
nnoremap <C-A> ggVG
nnoremap Y y$

" Smart tab and enter.
inoremap <expr> <Tab>   pumvisible() ? "\<C-n>" : "\<Tab>"
inoremap <expr> <S-Tab> pumvisible() ? "\<C-p>" : "\<S-Tab>"
inoremap <expr> <CR>    pumvisible() ? "\<C-y>" : "\<C-G>u\<CR>"

" Self-discipline:
nnoremap <Up>       <Cmd>echoe 'Use k'<CR>
nnoremap <Right>    <Cmd>echoe 'Use l'<CR>
nnoremap <Down>     <Cmd>echoe 'Use j'<CR>
nnoremap <Left>     <Cmd>echoe 'Use h'<CR>

inoremap <Up>       <Cmd>echoe 'Use ^k'<CR>
inoremap <Right>    <Cmd>echoe 'Use ^l'<CR>
inoremap <Down>     <Cmd>echoe 'Use ^j'<CR>
inoremap <Left>     <Cmd>echoe 'Use ^h'<CR>

nnoremap <C-Right>  <Cmd>echoe 'Use e or E or w or W'<CR>
nnoremap <C-Left>   <Cmd>echoe 'Use b or B'<CR>

inoremap <C-Right>  <Cmd>echoe 'Use e or E or w or W in NORMAL mode'<CR>
inoremap <C-Left>   <Cmd>echoe 'Use b or B in NORMAL mode'<CR>

" Tabpage.
nnoremap <Space>t :tabnew<Space>
nnoremap <Space>q <Cmd>tabclose<CR>
nnoremap <Space>[ <Cmd>tabprevious<CR>
nnoremap <Space>] <Cmd>tabNext<CR>
nnoremap <C-T> <Cmd>Texplore<CR>

" Scroll
nnoremap <C-K> 5k
nnoremap <C-J> 5j

" Auto pairs.
" inoremap " ""<Esc>i
" inoremap ' ''<Esc>i
" inoremap ( ()<Esc>i
" inoremap { {}<Esc>i
" inoremap [ []<Esc>i

" augroup PythonDocString
"     autocmd!
"     autocmd FileType python inoremap """<CR> """<CR>"""<Esc>O<Backspace>
"     autocmd FileType python inoremap '''<CR> '''<CR>'''<Esc>O<Backspace>
" augroup END
" inoremap (<CR> (<CR>)<Esc>O
" inoremap {<CR> {<CR>}<Esc>O
" inoremap [<CR] [<CR>]<Esc>O

" inoremap (<Space> ()<Esc>i<Space><Esc>i<Space>
" inoremap {<Space> {}<Esc>i<Space><Esc>i<Space>
" inoremap [<Space> []<Esc>i<Space><Esc>i<Space>

" Toggles
nnoremap <C-E> <Cmd>Lexplore<CR>
nnoremap <C-U> <Cmd>UndotreeToggle<CR>
nnoremap ++ <Cmd>set spell!<CR>
nnoremap _+ <Cmd>set hlsearch!<CR>

" Source Vimrc
nnoremap <Space>r <Cmd>source $MYVIMRC<CR>

" Commenting.
nmap <C-_> gcc
vmap <C-_> gc

" Vim-Plug shorts
nnoremap <Space>ps <Cmd>PlugInstall<CR>
nnoremap <Space>pr <Cmd>PlugClean<CR>

" Key mappings for COC.
nmap <Leader>rn <Plug>(coc-rename)
nmap <silent> gd <Plug>(coc-definition)
nmap <silent> gy <Plug>(coc-type-definition)
"nmap <silent> gi <Plug>(coc-implementation)
nmap <silent> gr <Plug>(coc-references)
nmap <Leader>qf  <Plug>(coc-fix-current)
nmap <silent> [g <Plug>(coc-diagnostic-prev)
nmap <silent> ]g <Plug>(coc-diagnostic-next)
nnoremap <silent><nowait> <Space>a  :<C-G>CocList diagnostics<CR>
nnoremap <silent><nowait> <Space>o  :<C-G>CocList outline<CR>

" Highlight the symbol and its references when holding the cursor.
autocmd CursorHold * silent call CocActionAsync('highlight')

" Use K to show documentation in preview window.
nnoremap <silent> K :call <SID>show_documentation()<CR>

function! s:show_documentation()
    if (index(['vim','help'], &filetype) >= 0)
        execute 'h '.expand('<cword>')
    elseif (coc#rpc#ready())
        call CocActionAsync('doHover')
    else
        execute '!' . &keywordprg . " " . expand('<cword>')
    endif
endfunction

